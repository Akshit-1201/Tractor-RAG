# --- OpenAI ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/tractor

# --- Auth ---
JWT_SECRET=change-me
JWT_EXPIRY_MINUTES=120
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- RAG tuning ---
# Values verified live against the four worked examples (spec Appendix A)
# with the bundled seed content (scripts/seed_content.py).
RETRIEVAL_TOP_K=8
IMAGE_SIMILARITY_THRESHOLD=0.35      # Gate 3 — compared against dense cosine similarity
CHUNK_TARGET_TOKENS=650
CHUNK_OVERLAP_TOKENS=80

# --- Limits / abuse protection ---
MAX_QUESTION_CHARS=10000              # /api/chat rejects longer questions (422)
MAX_HISTORY_MESSAGES=6              # recent turns the client may send for follow-up context
MAX_HISTORY_CHARS=40000             # per-message content cap in the sent history
CHAT_RATE_LIMIT=20/minute            # per-IP limit on /api/chat
LOGIN_RATE_LIMIT=10/minute           # per-IP limit on /api/admin/login (brute-force guard)
MAX_UPLOAD_MB=50                     # per-file upload cap (documents & images)

# --- Storage / server ---
STORAGE_PATH=/data/storage
FRONTEND_ORIGIN=http://localhost:5173
